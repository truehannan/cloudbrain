# CloudBrain Environment Configuration
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will NOT be committed

# Your Cloudflare KV Namespace IDs
# Get these from: wrangler kv:namespace list
CLOUDBRAIN_KV_PRODUCTION_ID=your_production_namespace_id_here
CLOUDBRAIN_KV_PREVIEW_ID=your_preview_namespace_id_here

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmnoPQRstuvWXYZ

# Your Telegram User ID (from @userinfobot)
TELEGRAM_OWNER_ID=987654321
