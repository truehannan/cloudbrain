# CloudBrain Environment Variables Example

# ===== REQUIRED: Telegram Bot =====
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmnoPQRstu-vwxyzABC

# Get your Telegram ID from @userinfobot on Telegram
TELEGRAM_OWNER_ID=987654321

# ===== REQUIRED: Cloudflare =====
# Your Cloudflare Account ID
# Find at: Dashboard → Sidebar → copy from URL or right panel
CLOUDFLARE_ACCOUNT_ID=abc123def456ghi789

# Your Cloudflare API Token
# Create at: Dashboard → Settings → API Tokens → Create Custom Token
# Needs: workers.scripts:write, workers.scripts:delete, d1:edit, kv:write, r2:write
CLOUDFLARE_API_TOKEN=v1.0abc123def456ghi789jkl

# ===== OPTIONAL: Additional Config =====
# Wrangler environment (development or production)
WRANGLER_ENV=production

# ===== Database (from wrangler.toml D1) =====
# After creating D1 database, add the ID here
D1_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===== KV Namespace (from wrangler.toml KV) =====
# After creating KV namespace, add the ID here
KV_NAMESPACE_ID=xxxxxxxx000000000000000000000000

# ===== R2 Bucket =====
# Bucket name (must match wrangler.toml)
R2_BUCKET_NAME=cloudbrain-files
