# CloudBrain Environment Variables
# Copy this file to .env.local and fill in your credentials

# ============================================================================
# CLOUDFLARE ACCOUNT CREDENTIALS (REQUIRED)
# ============================================================================
# Get from: https://dash.cloudflare.com/profile/api-tokens

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ============================================================================
# CLOUDFLARE BINDINGS (configured in Cloudflare Dashboard)
# ============================================================================
# These are NOT environment variables - they are bindings configured in:
# Cloudflare Dashboard → Workers & Pages → CloudBrain → Settings → Bindings
#
# REQUIRED Bindings (all 3 must be configured):
# 1. KV Namespace: SECRETS (stores all channel credentials)
#    - KV Namespace Name: cloudbrain
#    - Binding Variable Name: SECRETS
#
# 2. D1 Database: DB (stores memories)
#    - Database Name: cloudbrain
#    - Binding Variable Name: DB
#
# 3. AI: AI (Cloudflare AI Gateway for Llama 2)
#    - Binding Variable Name: AI

# ============================================================================
# CHANNEL CREDENTIALS (OPTIONAL - Choose at least one)
# ============================================================================
# Add credentials for channels you want to use
# If no credentials are provided, that channel will be disabled

# --- TELEGRAM (Optional) ---
# Get from: https://t.me/BotFather (create bot) and @userinfobot (get ID)
# KV Key Names: SECRET_TELEGRAM_API_TOKEN, TELEGRAM_OWNER_ID

SECRET_TELEGRAM_API_TOKEN=
TELEGRAM_OWNER_ID=

# --- DISCORD (Optional) ---
# Get from: https://discord.com/developers/applications
# KV Key Names: DISCORD_BOT_TOKEN, DISCORD_CLIENT_ID, DISCORD_WEBHOOK_URL

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_WEBHOOK_URL=

# --- WHATSAPP (Optional) ---
# Get from: https://developers.facebook.com/docs/whatsapp/cloud-api
# KV Key Names: WHATSAPP_PHONE_NUMBER_ID, WHATSAPP_BUSINESS_ACCOUNT_ID, WHATSAPP_ACCESS_TOKEN, WHATSAPP_VERIFY_TOKEN

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
